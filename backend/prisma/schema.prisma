generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  STUDENT
  GRADUATE
  COMPANY
  INSTITUTION
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role
  isVerified   Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  otpCodes         OtpCode[]
  resetTokens      ResetToken[]
  candidateProfile   CandidateProfile?
  companyProfile     CompanyProfile?
  institutionProfile InstitutionProfile?

  @@map("users")
}

model OtpCode {
  id        String   @id @default(uuid())
  code      String
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, used, expiresAt])
  @@map("otp_codes")
}

model ResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reset_tokens")
}

model CandidateProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  fullName       String?
  phone          String?
  photoUrl       String?
  summary        String?
  career         String?
  semester       Int?
  graduationYear Int?
  institution    String?
  skills         String[]
  softSkills     String[]
  languages      Json?
  projects       Json?
  certifications Json?
  cvUrl          String?
  salaryExpected Int?
  workMode       String?
  notificationsEnabled Boolean  @default(true)
  notificationChannel  String   @default("telegram")
  telegramChatId       String?
  reputationAvg        Float    @default(0)
  ratingCount          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  applications   Application[]
  contracts Contract[]
  score          ProfileScore?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([career])
  @@index([notificationsEnabled, telegramChatId])
  @@map("candidate_profiles")
}

model CompanyProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  companyName   String?
  nit           String?
  sector        String?
  employeeCount String?
  description   String?
  logoUrl       String?
  website       String?
  contactEmail  String?
  contactPhone  String?
  city          String?
  reputationAvg Float    @default(0)
  ratingCount   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  jobs          Job[]
  contracts Contract[]
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("company_profiles")
}

enum JobType {
  FORMAL      // Contrato formal
  FREELANCE   // Proyecto puntual / microwork
}

enum JobStatus {
  ACTIVE      // Visible para candidatos
  SELECTING   // En proceso de selección
  CLOSED      // Cerrada — ya se seleccionó
  CANCELLED   // Cancelada por la empresa
}

enum ApplicationStatus {
  RECEIVED    // Postulación recibida
  REVIEWING   // En revisión por la empresa
  SELECTED    // Candidato seleccionado
  REJECTED    // Candidato descartado
}

enum WorkMode {
  REMOTE
  ONSITE
  HYBRID
}

model Job {
  id           String    @id @default(uuid())
  companyId    String
  title        String
  description  String
  type         JobType
  status       JobStatus @default(ACTIVE)
  workMode     WorkMode
  area         String?
  skills       String[]
  budgetMin    Int?
  budgetMax    Int?
  duration     String?
  deadline     DateTime?
  deliverables String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company      CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[]
  rankConfig   JobRankConfig?
  contracts Contract[]

  @@index([companyId])
  @@index([status])
  @@map("jobs")
}

model Application {
  id           String            @id @default(uuid())
  jobId        String
  candidateId  String
  status       ApplicationStatus @default(RECEIVED)
  scoreAtApply Float?
  aiReasons    String[]          @default([])
  aiGaps       String[]          @default([])
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  job       Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  contract  Contract?

  @@unique([jobId, candidateId])
  @@index([jobId])
  @@index([candidateId])
  @@map("applications")
}

model JobRankConfig {
  id               String  @id @default(uuid())
  jobId            String  @unique
  skillsWeight     Float   @default(0.30)
  experienceWeight Float   @default(0.25)
  educationWeight  Float   @default(0.15)
  certsWeight      Float   @default(0.10)
  reputationWeight Float   @default(0.10)
  languagesWeight  Float   @default(0.05)
  completionWeight Float   @default(0.05)

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_rank_configs")
}

model ProfileScore {
  id               String   @id @default(uuid())
  candidateId      String   @unique
  totalScore       Float    @default(0)
  skillsScore      Float    @default(0)
  experienceScore  Float    @default(0)
  educationScore   Float    @default(0)
  certsScore       Float    @default(0)
  reputationScore  Float    @default(0)
  languagesScore   Float    @default(0)
  completionScore  Float    @default(0)
  calculatedAt     DateTime @default(now())

  candidate CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([totalScore])
  @@map("profile_scores")
}

enum KeywordType {
  TECHNICAL   // Habilidades técnicas → va a skills[]
  SOFT        // Habilidades blandas → va a softSkills[]
  LANGUAGE    // Idiomas → va a languages JSON
}

model Keyword {
  id        String      @id @default(uuid())
  name      String      @unique
  type      KeywordType
  category  String      // ej: "Desarrollo Web", "Diseño", "Administración"
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())

  @@map("keywords")
}

enum ContractStatus {
  PENDING_CANDIDATE
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  CONFIRMED
}

enum PaymentScheme {
  SINGLE
  MILESTONES
  PERIODIC
}

enum DeliverableStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum RatingRaterRole {
  COMPANY
  CANDIDATE
}

model Contract {
  id              String         @id @default(uuid())
  jobId           String
  candidateId     String
  companyId       String
  applicationId   String?        @unique
  title           String
  description     String
  deliverables    String
  startDate       DateTime
  endDate         DateTime
  totalAmount     Int
  paymentScheme   PaymentScheme  @default(SINGLE)
  contractFileUrl String?
  status          ContractStatus @default(PENDING_CANDIDATE)
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  job         Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  company     CompanyProfile   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  application Application?     @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  payments    Payment[]
  deliverableItems Deliverable[]
  ratings     ContractRating[]

  @@index([companyId])
  @@index([candidateId])
  @@index([status])
  @@map("contracts")
}

model ContractRating {
  id                   String          @id @default(uuid())
  contractId           String
  raterRole            RatingRaterRole
  quality              Int?
  deadlines            Int?
  communication        Int?
  attitude             Int?
  paymentPunctuality   Int?
  instructionClarity   Int?
  workEnvironment      Int?
  overallScore         Float
  comment              String?
  createdAt            DateTime        @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, raterRole])
  @@map("contract_ratings")
}

model GlobalRankConfig {
  id               String @id @default("global")
  skillsWeight     Float  @default(0.20)
  experienceWeight Float  @default(0.20)
  educationWeight  Float  @default(0.20)
  certsWeight      Float  @default(0.10)
  reputationWeight Float  @default(0.10)
  languagesWeight  Float  @default(0.05)
  completionWeight Float  @default(0.20)
  updatedAt        DateTime @updatedAt

  @@map("global_rank_config")
}

model InstitutionProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  institutionName String
  contactEmail    String?
  contactPhone    String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("institution_profiles")
}

model Deliverable {
  id              String            @id @default(uuid())
  contractId      String
  title           String
  description     String            @default("")
  dueDate         DateTime?
  status          DeliverableStatus @default(PENDING)
  fileUrl         String?
  candidateNotes  String?
  companyFeedback String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("deliverables")
}

model Payment {
  id          String        @id @default(uuid())
  contractId  String
  amount      Int
  description String        @default("")
  dueDate     DateTime?
  sequence    Int           @default(1)
  receiptUrl  String?
  status      PaymentStatus @default(PENDING)
  confirmedAt DateTime?
  createdAt   DateTime      @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("payments")
}