PORT=3001
NODE_ENV=development

# PostgreSQL (Supabase). DATABASE_URL puede usar pooler; DIRECT_URL conexión directa para migraciones.
DATABASE_URL=
DIRECT_URL=

SUPABASE_URL=
SUPABASE_ANON_KEY=

JWT_SECRET=
JWT_EXPIRES_IN=7d

OTP_EXPIRES_MINUTES=10
RESET_TOKEN_EXPIRES_MINUTES=15

FRONTEND_URL=http://localhost:3000

# Brevo API (Transactional → SMTP & API en el panel Brevo; usar API key xkeysib-...)
# HTTPS evita bloqueo SMTP en Railway Hobby/Free. Remitente debe estar verificado en Brevo.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=remitente-verificado@ejemplo.com
BREVO_SENDER_NAME=TalentBridge

GEMINI_API_KEY=

N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
TELEGRAM_BOT_TOKEN=
