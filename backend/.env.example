PORT=3001
NODE_ENV=development

DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=

JWT_SECRET=
JWT_EXPIRES_IN=7d

OTP_EXPIRES_MINUTES=10
RESET_TOKEN_EXPIRES_MINUTES=15

FRONTEND_URL=http://localhost:3000

# Brevo SMTP (Transactional → SMTP & API en el panel Brevo)
# Usar sendinblue.com: el cert TLS del relay (p. ej. SA) no incluye smtp-relay.brevo.com
SMTP_HOST=smtp-relay.sendinblue.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TalentBridge <remitente-verificado@ejemplo.com>

GEMINI_API_KEY=

N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
TELEGRAM_BOT_TOKEN=
